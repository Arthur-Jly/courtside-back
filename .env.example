# --- Server ---
NODE_ENV=development
PORT=3001
# Comma-separated allowlist of origins. NEVER use "*" in production.
CORS_ORIGIN=http://localhost:5173

# --- Database (MySQL) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=sport

# --- Auth ---
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# Must be at least 32 chars. NEVER ship a default value.
JWT_SECRET=replace-with-strong-random-48-byte-base64
JWT_TTL=2h
BCRYPT_ROUNDS=12

# --- Third-party services ---
# Server-side ONLY: do not expose to the frontend.
GOOGLE_MAPS_API_KEY=
PRIVATE_STRIPE_KEY=
STRIPE_WEBHOOK_SECRET=

# Public frontend URL used to build Stripe redirect URLs.
FRONTEND_URL=http://localhost:5173
